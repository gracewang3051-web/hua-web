{
  "title": "\u8bed\u6587\u95ea\u5361",
  "cards": [
    {
      "front": "\u5728\u4f5c\u6587\u5ba1\u9898\u5efa\u6a21\u4e2d\uff0c\u6240\u8c13\u7684\u201c\u5efa\u6a21\u601d\u7ef4\u201d\u4e3b\u8981\u6d4b\u8bd5\u5b66\u751f\u7684\u4ec0\u4e48\u80fd\u529b\uff1f",
      "back": "\u5c06\u62bd\u8c61\u9898\u76ee\u843d\u5230\u5b9e\u5904\uff0c\u8fd0\u7528\u7279\u5b9a\u516c\u5f0f\u6216\u539f\u7406\u8fdb\u884c\u903b\u8f91\u63a8\u5bfc\u7684\u80fd\u529b\u3002"
    },
    {
