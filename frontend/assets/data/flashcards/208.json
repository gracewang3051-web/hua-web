{
  "title": "\u8bed\u6587\u62bd\u8ba4\u5361",
  "cards": [
    {
      "front": "\u5728\u8bae\u8bba\u6587\u5ba1\u9898\u5efa\u6a21\u4e2d\uff0c\u4ec0\u4e48\u662f\u201c\u793e\u4f1a\u4f20\u67d3\u73b0\u8c61\u201d\uff1f",
      "back": "\u6307\u751f\u6d3b\u4e2d\u4ed6\u4eba\u901a\u8fc7\u601d\u60f3\u3001\u60c5\u611f\u548c\u884c\u4e3a\uff0c\u5f71\u54cd\u6211\u4eec\u5bf9\u4e8b\u7269\u7684\u8ba4\u77e5\u5224\u65ad\uff0c\u751a\u81f3\u6539\u53d8\u6211\u4eec\u884c\u4e3a\u7684\u73b0\u8c61\u3002"
